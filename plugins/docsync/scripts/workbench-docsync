#!/usr/bin/env bash
# workbench-docsync — public CLI shim for the claude-workbench docsync plugin.
#
# Sibling plugins invoke this for capability detection:
#   workbench-docsync --health
# and for the kanban DONE gate:
#   workbench-docsync check --since "$(git merge-base HEAD main)" --format json
set -euo pipefail

if [ -n "${DOCSYNC_CLI_PY:-}" ] && [ -f "$DOCSYNC_CLI_PY" ]; then
  cli="$DOCSYNC_CLI_PY"
else
  # Resolve symlinks so we find the real plugin dir even when this shim was
  # installed via `ln -s` into ~/.claude-workbench/bin/.
  src="${BASH_SOURCE[0]}"
  while [ -L "$src" ]; do
    target="$(readlink "$src")"
    case "$target" in
      /*) src="$target" ;;
      *)  src="$(cd -- "$(dirname -- "$src")" && pwd)/$target" ;;
    esac
  done
  here="$(cd -- "$(dirname -- "$src")" && pwd)"
  if [ -f "$here/workbench-docsync.py" ]; then
    cli="$here/workbench-docsync.py"
  elif [ -f "$here/../scripts/workbench-docsync.py" ]; then
    cli="$here/../scripts/workbench-docsync.py"
  else
    echo "workbench-docsync: cannot locate workbench-docsync.py (set DOCSYNC_CLI_PY)" >&2
    exit 1
  fi
fi

exec python3 "$cli" "$@"
