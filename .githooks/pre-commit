#!/usr/bin/env python3
"""pre-commit hook — enforce plugin version bump on every change.

If anything under plugins/<name>/ is staged, the version in BOTH
  - plugins/<name>/.claude-plugin/plugin.json
  - the matching entry in .claude-plugin/marketplace.json
must change relative to HEAD, and they must agree with each other.

Bypass: git commit --no-verify (only when intentional, e.g. branch testing).
"""
from __future__ import annotations

import json
import subprocess
import sys


def run(args: list[str], cwd: str | None = None) -> str | None:
    try:
        return subprocess.check_output(args, cwd=cwd, text=True, stderr=subprocess.DEVNULL)
    except subprocess.CalledProcessError:
        return None


def repo_root() -> str:
    out = run(["git", "rev-parse", "--show-toplevel"])
    if not out:
        sys.exit(0)  # not a git repo somehow — let it through
    return out.strip()


def staged_files(cwd: str) -> list[str]:
    out = run(["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR"], cwd) or ""
    return [line.strip() for line in out.splitlines() if line.strip()]


def at_head(path: str, cwd: str) -> str | None:
    return run(["git", "show", f"HEAD:{path}"], cwd)


def at_index(path: str, cwd: str) -> str | None:
    """Return the staged (index) version of `path`. If `path` was not staged
    in this commit, this still returns its current index content (== HEAD)."""
    return run(["git", "show", f":{path}"], cwd)


def plugin_version(blob: str | None) -> str | None:
    if not blob:
        return None
    try:
        v = json.loads(blob).get("version")
    except json.JSONDecodeError:
        return None
    return v if isinstance(v, str) else None


def marketplace_version(blob: str | None, name: str) -> str | None:
    if not blob:
        return None
    try:
        data = json.loads(blob)
    except json.JSONDecodeError:
        return None
    for entry in data.get("plugins", []):
        if entry.get("name") == name:
            v = entry.get("version")
            return v if isinstance(v, str) else None
    return None


def main() -> int:
    cwd = repo_root()
    files = staged_files(cwd)
    if not files:
        return 0

    affected: set[str] = set()
    for f in files:
        if f.startswith("plugins/"):
            parts = f.split("/", 2)
            if len(parts) >= 2 and parts[1]:
                affected.add(parts[1])

    if not affected:
        return 0

    mk_head = at_head(".claude-plugin/marketplace.json", cwd)
    mk_now = at_index(".claude-plugin/marketplace.json", cwd)

    errors: list[str] = []

    for name in sorted(affected):
        pj = f"plugins/{name}/.claude-plugin/plugin.json"
        head_blob = at_head(pj, cwd)
        now_blob = at_index(pj, cwd)
        if now_blob is None:
            continue  # plugin being removed — let it through

        head_v = plugin_version(head_blob)
        now_v = plugin_version(now_blob)

        # New plugin (no HEAD version) — let it pass
        if head_v is not None and head_v == now_v:
            errors.append(
                f"  - {name}: plugins/{name}/ has staged changes but "
                f"plugin.json version is still {now_v} — bump it (e.g. patch+1)."
            )

        head_mv = marketplace_version(mk_head, name)
        now_mv = marketplace_version(mk_now, name)
        if now_mv is None:
            continue  # plugin missing from marketplace — separate concern
        if head_mv is not None and head_mv == now_mv:
            errors.append(
                f"  - {name}: .claude-plugin/marketplace.json entry version "
                f"is still {now_mv} — bump it to match plugin.json."
            )
        if now_v is not None and now_mv is not None and now_v != now_mv:
            errors.append(
                f"  - {name}: version drift — plugin.json={now_v} vs "
                f"marketplace.json={now_mv}. Make them equal."
            )

    if errors:
        sys.stderr.write(
            "\npre-commit: plugin version-bump check failed.\n\n"
            + "\n".join(errors)
            + "\n\nFix: bump the version in both plugin.json AND the matching\n"
            "     entry in .claude-plugin/marketplace.json, then re-stage and re-commit.\n"
            "Bypass (only when intentional): git commit --no-verify\n\n"
        )
        return 1

    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as e:
        sys.stderr.write(f"pre-commit hook crashed (allowing commit): {e}\n")
        sys.exit(0)
